# .env.example — copy to .env for local development
# Never commit .env

# Admin password (local dev default — use something stronger in production via SSM)
ADMIN_PASSWORD=memm2025

# JWT signing secret (local dev only — use a long random string in production)
JWT_SECRET=dev-only-change-this-in-prod

# Express port for local dev
PORT=3001

# AWS region (used by AWS SDK in local dev when calling DynamoDB/S3)
AWS_REGION=us-east-1

# DynamoDB table names (override for local dev if using a local DynamoDB)
# TOURNAMENT_TABLE=torn-march-madness-tournament
# VOTES_TABLE=torn-march-madness-votes

# S3 bucket for team images
# IMAGES_BUCKET=memm-uploads-<your-account-id>

# CORS origins (comma-separated; local dev defaults handled in server.js)
# CORS_ORIGINS=http://localhost:5173

# API Gateway base URL — only needed for frontend production build
# VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
